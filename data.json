{
  "variables": [
    {
      "category": "nvidia_commands",
      "variables": [
        { "title": "dlss4_upgrade", "env": "PROTON_DLSS4_UPGRADE", "type": "bool", "value": "1" },
        { "title": "dlss_indicator", "env": "PROTON_DLSS_INDICATOR", "type": "bool", "value": "1" },
        { "title": "smooth_motion", "env": "NVPRESENT_ENABLE_SMOOTH_MOTION", "type": "bool", "value": "1" }
      ]
    },
    {
      "category": "amd_commands",
      "variables": [
        { "title": "fsr4_upgrade", "env": "PROTON_FSR4_UPGRADE", "type": "bool", "value": "1" },
        { "title": "fsr4_rdna3_upgrade", "env": "PROTON_FSR4_RDNA3_UPGRADE", "type": "bool", "value": "1" },
        { "title": "fsr_indicator", "env": "PROTON_FSR4_INDICATOR", "type": "bool", "value": "1" }
      ]
    },
    {
      "category": "intel_commands",
      "variables": [
        { "title": "xess_upgrade", "env": "PROTON_XESS_UPGRADE", "type": "bool", "value": "1" },
        { "title": "xess_indicator", "env": "PROTON_XESS_INDICATOR", "type": "bool", "value": "1" }
      ]
    },
    {
      "category": "wrappers",
      "variables": [
        { "title": "lsfg", "env": "__LSFG", "type": "bool", "value": "1", "simple": true },
        { "title": "fgmod", "env": "__FGMOD", "type": "bool", "value": "1", "simple": true }
      ]
    },
    {
      "category": "performance",
      "variables": [
        { "title": "dxvk_async", "env": "DXVK_ASYNC", "type": "bool", "value": "1" },
        { "title": "ntsync", "env": "PROTON_USE_NTSYNC", "type": "bool", "value": "1" },
        {
          "title": "radv_perftest",
          "env": "RADV_PERFTEST",
          "type": "enum",
          "defaultValue": "aco",
          "values": [
            { "title": "radv_perftest_aco", "value": "aco" },
            { "title": "radv_perftest_gpl", "value": "gpl" }
          ]
        }
      ]
    },
    {
      "category": "compatibility",
      "variables": [
        { "title": "wined3d", "env": "PROTON_USE_WINED3D", "type": "bool", "value": "1" },
        { "title": "nvidia_gpu_masking", "env": "PROTON_HIDE_NVIDIA_GPU", "type": "bool", "value": "1" },
        { "title": "nvapi", "env": "PROTON_ENABLE_NVAPI", "type": "bool", "value": "1" },
        { "title": "hdr_wsi", "env": "ENABLE_HDR_WSI", "type": "bool", "value": "1" },
        { "title": "hdr", "env": "PROTON_ENABLE_HDR", "type": "bool", "value": "1" },
        { "title": "vkd3d_heap", "env": "PROTON_VKD3D_HEAP", "type": "bool", "value": "1" },
        { "title": "steam_deck", "env": "SteamDeck", "type": "bool", "value": "0" }
      ]
    },
    {
      "category": "debug",
      "variables": [
        { "title": "proton_log", "env": "PROTON_LOG", "type": "bool", "value": "1" },
        { "title": "mangohud", "env": "MANGOHUD", "type": "bool", "value": "1" },
        {
          "title": "mangohud_config",
          "env": "MANGOHUD_CONFIG",
          "type": "enum",
          "defaultValue": "fps_only=1",
          "values": [
            { "title": "mangohud_no_display", "value": "no_display" },
            { "title": "mangohud_fps_only", "value": "fps_only=1" },
            { "title": "mangohud_medium", "value": "cpu_stats,gpu_stats,fps,frametime" },
            { "title": "mangohud_extended", "value": "cpu_stats,gpu_stats,fps,frametime,cpu_temp,gpu_temp,vram,ram,gpu_power" },
            { "title": "mangohud_full", "value": "full" }
          ]
        }
      ]
    }
  ],
